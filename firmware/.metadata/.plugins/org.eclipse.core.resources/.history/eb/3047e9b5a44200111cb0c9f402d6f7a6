#include "ladder_vm.h"
#include "io_image.h"
#include "timer_counter.h"

#define VM_STACK_SIZE 16
#define SCAN_PERIOD_MS 10   // matches TIM2 period

static bool vm_read_addr(uint8_t addr) {
    if (addr <= 0x07) {
        return g_io.digital_in[addr];
    } else if (addr >= 0x10 && addr <= 0x17) {
        return g_io.digital_out[addr - ADDR_OUTPUT_BASE];
    } else if (addr >= 0x20 && addr <= 0x27) {
        return g_timers[addr - ADDR_TIMER_BASE].output;
    } else if (addr >= 0x30 && addr <= 0x37) {
        return g_counters[addr - ADDR_COUNTER_BASE].output;
    }
    return false;
}

static void vm_write_addr(uint8_t addr, bool value) {
    if (addr >= 0x10 && addr <= 0x17) {
        g_io.digital_out[addr - ADDR_OUTPUT_BASE] = value;
    }
}
// Read a numeric value from an address (counter count, timer elapsed, or bit value)
static uint16_t vm_read_addr_value(uint8_t addr) {
    if (addr >= 0x20 && addr <= 0x27) {
        // Timer addresses — return elapsed_ms (you could /1000 if you want seconds)
        return g_timers[addr - ADDR_TIMER_BASE].elapsed_ms;
    } else if (addr >= 0x30 && addr <= 0x37) {
        // Counter addresses — return current count
        return g_counters[addr - ADDR_COUNTER_BASE].count;
    }
    // For digital inputs/outputs, return 0 or 1 as a number
    return vm_read_addr(addr) ? 1 : 0;
}
vm_result_t ladder_vm_execute(const uint8_t *program, uint16_t program_len) {
    bool stack[VM_STACK_SIZE];
    int sp = -1;
    uint16_t pc = 0;

    while (pc < program_len) {
        uint8_t opcode = program[pc++];

        if (opcode == OP_END) return VM_OK;

        // Multi-byte opcodes: TON/CTU have operand + preset (3 bytes total)
        if (opcode == OP_TON || opcode == OP_CTU) {
            if (pc + 2 >= program_len) return VM_ERR_PROGRAM_TOO_LONG;

            uint8_t addr      = program[pc++];
            uint16_t preset   = program[pc++];
            preset |= ((uint16_t)program[pc++]) << 8;

            bool input = (sp >= 0) ? stack[sp] : false;

            if (opcode == OP_TON) {
                uint8_t idx = addr - ADDR_TIMER_BASE;
                if (idx >= PLC_TIMER_COUNT) return VM_ERR_INVALID_ADDR;
                plc_timer_t *t = &g_timers[idx];

                if (input) {
                    if (!t->prev_input) t->elapsed_ms = 0;  // rising edge
                    else t->elapsed_ms += SCAN_PERIOD_MS;

                    if (t->elapsed_ms >= preset) t->output = true;
                } else {
                    t->elapsed_ms = 0;
                    t->output = false;
                }
                t->prev_input = input;
            }
            else {  // OP_CTU
                uint8_t idx = addr - ADDR_COUNTER_BASE;
                if (idx >= PLC_COUNTER_COUNT) return VM_ERR_INVALID_ADDR;
                plc_counter_t *c = &g_counters[idx];

                // Rising edge detection
                if (input && !c->prev_input) {
                    if (c->count < 0xFFFF) c->count++;
                }
                c->prev_input = input;
                c->output = (c->count >= preset);
            }
            continue;
        }
        // Multi-byte opcodes: TON/CTU have operand + preset (3 bytes total)
        if (opcode == OP_TON || opcode == OP_CTU) {
            // ... existing code
        }
        // LDEQ: load HIGH if value at addr equals immediate (3 bytes after opcode)
        if (opcode == OP_LDEQ) {
            if (pc + 2 >= program_len) return VM_ERR_PROGRAM_TOO_LONG;

            uint8_t addr      = program[pc++];
            uint16_t compare  = program[pc++];
            compare |= ((uint16_t)program[pc++]) << 8;

            uint16_t actual = vm_read_addr_value(addr);

            if (sp + 1 >= VM_STACK_SIZE) return VM_ERR_STACK_OVERFLOW;
            stack[++sp] = (actual == compare);
            continue;
        }
        // Single-operand opcodes (1 byte address after opcode)
        if (pc >= program_len) return VM_ERR_PROGRAM_TOO_LONG;
        uint8_t addr = program[pc++];
        bool value = vm_read_addr(addr);

        switch (opcode) {
            case OP_LD:
            case OP_LDT:
            case OP_LDC:
                if (sp + 1 >= VM_STACK_SIZE) return VM_ERR_STACK_OVERFLOW;
                stack[++sp] = value;
                break;

            case OP_LDN:
                if (sp + 1 >= VM_STACK_SIZE) return VM_ERR_STACK_OVERFLOW;
                stack[++sp] = !value;
                break;

            case OP_AND:
                if (sp >= 0) stack[sp] = stack[sp] && value;
                break;

            case OP_ANDN:
                if (sp >= 0) stack[sp] = stack[sp] && !value;
                break;

            case OP_OR:
                if (sp >= 0) stack[sp] = stack[sp] || value;
                break;

            case OP_ORN:
                if (sp >= 0) stack[sp] = stack[sp] || !value;
                break;

            case OP_OUT:
                if (sp >= 0) vm_write_addr(addr, stack[sp]);
                break;

            case OP_RST:
                if (addr >= 0x20 && addr <= 0x27) {
                    plc_timer_t *t = &g_timers[addr - ADDR_TIMER_BASE];
                    t->elapsed_ms = 0;
                    t->output = false;
                } else if (addr >= 0x30 && addr <= 0x37) {
                    plc_counter_t *c = &g_counters[addr - ADDR_COUNTER_BASE];
                    c->count = 0;
                    c->output = false;
                }
                break;

            default:
                return VM_ERR_UNKNOWN_OPCODE;
        }
    }

    return VM_OK;
}
