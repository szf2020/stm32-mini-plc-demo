#include "eeprom.h"
#include "main.h"
#include <string.h>

extern I2C_HandleTypeDef hi2c1;

#define EEPROM_TIMEOUT_MS 100

bool eeprom_init(void) {
    // Probe the device: try reading 1 byte at address 0
    uint8_t dummy;
    if (HAL_I2C_IsDeviceReady(&hi2c1, EEPROM_I2C_ADDR, 3, EEPROM_TIMEOUT_MS) != HAL_OK) {
        return false;
    }
    return eeprom_read_byte(0, &dummy);
}

bool eeprom_write_byte(uint16_t addr, uint8_t value) {
    uint8_t buf[3];
    buf[0] = (addr >> 8) & 0xFF;   // high byte of memory address
    buf[1] = addr & 0xFF;          // low byte
    buf[2] = value;

    if (HAL_I2C_Master_Transmit(&hi2c1, EEPROM_I2C_ADDR, buf, 3, EEPROM_TIMEOUT_MS) != HAL_OK) {
        return false;
    }

    // Wait for the internal write cycle (~5ms typical, up to 10ms)
    HAL_Delay(6);
    return true;
}

bool eeprom_read_byte(uint16_t addr, uint8_t *value) {
    uint8_t addr_buf[2];
    addr_buf[0] = (addr >> 8) & 0xFF;
    addr_buf[1] = addr & 0xFF;

    // First write the address we want to read from
    if (HAL_I2C_Master_Transmit(&hi2c1, EEPROM_I2C_ADDR, addr_buf, 2, EEPROM_TIMEOUT_MS) != HAL_OK) {
        return false;
    }

    // Then read the data
    if (HAL_I2C_Master_Receive(&hi2c1, EEPROM_I2C_ADDR, value, 1, EEPROM_TIMEOUT_MS) != HAL_OK) {
        return false;
    }

    return true;
}

bool eeprom_write_block(uint16_t addr, const uint8_t *data, uint16_t len) {
    // Write byte-by-byte (simple and safe). Page writes are faster but more complex.
    for (uint16_t i = 0; i < len; i++) {
        if (!eeprom_write_byte(addr + i, data[i])) {
            return false;
        }
    }
    return true;
}

bool eeprom_read_block(uint16_t addr, uint8_t *data, uint16_t len) {
    if (len == 0) return true;

    uint8_t addr_buf[2];
    addr_buf[0] = (addr >> 8) & 0xFF;
    addr_buf[1] = addr & 0xFF;

    // Write the start address
    if (HAL_I2C_Master_Transmit(&hi2c1, EEPROM_I2C_ADDR, addr_buf, 2, EEPROM_TIMEOUT_MS) != HAL_OK) {
        return false;
    }

    // Then read all bytes in one go (auto-increment in EEPROM)
    if (HAL_I2C_Master_Receive(&hi2c1, EEPROM_I2C_ADDR, data, len, EEPROM_TIMEOUT_MS + len) != HAL_OK) {
        return false;
    }

    return true;
}

bool eeprom_test(void) {
    // Write known values, read back, verify
    if (!eeprom_write_byte(0x0000, 0xA5)) return false;
    if (!eeprom_write_byte(0x0001, 0x5A)) return false;

    uint8_t v1 = 0, v2 = 0;
    if (!eeprom_read_byte(0x0000, &v1)) return false;
    if (!eeprom_read_byte(0x0001, &v2)) return false;

    return (v1 == 0xA5 && v2 == 0x5A);
}
// Compute the start address of a slot
static uint16_t slot_address(uint8_t slot) {
    return (uint16_t)slot * EEPROM_SLOT_SIZE;
}

bool eeprom_save_slot(uint8_t slot, const uint8_t *data, uint16_t len) {
    if (slot >= EEPROM_SLOT_COUNT) return false;
    if (len > EEPROM_SLOT_DATA_MAX) return false;

    uint16_t base = slot_address(slot);

    // Build the header (magic + length)
    uint8_t header[4];
    header[0] = EEPROM_MAGIC_1;
    header[1] = EEPROM_MAGIC_2;
    header[2] = len & 0xFF;
    header[3] = (len >> 8) & 0xFF;

    // Write the bytecode FIRST, then the header — so a crash mid-write
    // leaves an invalid slot rather than a corrupt valid-looking one
    if (!eeprom_write_block(base + 4, data, len)) return false;
    if (!eeprom_write_block(base, header, 4)) return false;

    return true;
}

bool eeprom_slot_is_valid(uint8_t slot) {
    if (slot >= EEPROM_SLOT_COUNT) return false;
    uint8_t magic[2];
    if (!eeprom_read_block(slot_address(slot), magic, 2)) return false;
    return (magic[0] == EEPROM_MAGIC_1 && magic[1] == EEPROM_MAGIC_2);
}

uint16_t eeprom_slot_length(uint8_t slot) {
    if (!eeprom_slot_is_valid(slot)) return 0;
    uint8_t lenbuf[2];
    if (!eeprom_read_block(slot_address(slot) + 2, lenbuf, 2)) return 0;
    return ((uint16_t)lenbuf[1] << 8) | lenbuf[0];
}

bool eeprom_load_slot(uint8_t slot, uint8_t *data, uint16_t *len_out, uint16_t max_len) {
    if (!eeprom_slot_is_valid(slot)) return false;

    uint16_t len = eeprom_slot_length(slot);
    if (len == 0 || len > max_len) return false;

    if (!eeprom_read_block(slot_address(slot) + 4, data, len)) return false;
    *len_out = len;
    return true;
}
