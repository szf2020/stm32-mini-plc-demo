#ifndef INC_LADDER_VM_H_
#define INC_LADDER_VM_H_

#include <stdint.h>
#include <stdbool.h>

// Opcodes for the ladder VM
#define OP_LD    0x01
#define OP_LDN   0x02
#define OP_AND   0x03
#define OP_ANDN  0x04
#define OP_OR    0x05
#define OP_ORN   0x06
#define OP_OUT   0x10
#define OP_END   0xFF
// Timer/Counter opcodes
#define OP_TON   0x20    // Timer ON-delay: TON T0, 5000 (5 sec)
#define OP_CTU   0x21    // Counter Up:     CTU C0, 10
#define OP_LDT   0x22    // Load timer output:   LDT T0 (read timer.output)
#define OP_LDC   0x23    // Load counter output: LDC C0 (read counter.output)
#define OP_RST   0x30    // Reset timer or counter

// Timer/Counter address space
#define ADDR_TIMER_BASE   0x20    // T0..T7 = 0x20..0x27
#define ADDR_COUNTER_BASE 0x30    // C0..C7 = 0x30..0x37

// Address space encoding
#define ADDR_INPUT_BASE   0x00    // I0..I7 = 0x00..0x07
#define ADDR_OUTPUT_BASE  0x10    // Q0..Q7 = 0x10..0x17

// Result codes
typedef enum {
    VM_OK = 0,
    VM_ERR_UNKNOWN_OPCODE,
    VM_ERR_INVALID_ADDR,
    VM_ERR_STACK_OVERFLOW,
    VM_ERR_PROGRAM_TOO_LONG
} vm_result_t;

// Execute one full pass of the ladder program
vm_result_t ladder_vm_execute(const uint8_t *program, uint16_t program_len);

#endif /* INC_LADDER_VM_H_ */
